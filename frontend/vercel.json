{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "env": {
    "VITE_API_URL": "https://mandi-deals-backend-production.up.railway.app"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://mandi-deals-backend-production.up.railway.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
